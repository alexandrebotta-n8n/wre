# =============================================================================
# DEV LOCAL — copie para .env e ajuste
# =============================================================================

# Postgres do docker-compose.yml local (porta 5435)
DATABASE_URL="postgresql://wre:wre@localhost:5435/wre_simulador?schema=public"

# Auth.js v5 — gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
# Decisão atual: apenas login email/senha. Google OAuth foi removido.

# =============================================================================
# PRODUÇÃO (Vercel + Neon Postgres)
# =============================================================================
# Configure as MESMAS variáveis acima no dashboard da Vercel:
#   Project Settings → Environment Variables
#
# DATABASE_URL  → Neon (recomendado): connection string com ?sslmode=require
#                 OU Vercel Postgres: usar a Pooled Connection String
# AUTH_SECRET   → mesmo segredo gerado (NÃO compartilhar com o de dev)
# AUTH_TRUST_HOST = "true"
#
# A migração roda automaticamente no build via vercel.json:
#   prisma generate && prisma migrate deploy && next build
#
# Após o 1º deploy, rode o seed manualmente uma vez:
#   - Connect ao DB de produção via psql/Studio
#   - Ou rode `npm run seed` localmente apontando para DATABASE_URL de produção
