# DATABASE_URL_TEST="postgresql://wre:wre@localhost:5434/wre_simulador_test?schema=public"

# Auth.js v5 — gere com: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
